# Portal provisioning configuration.
# Edit these to point at your own client app / assets. Both provision.sh and
# provision.ps1 read this file.

# Package + components of the client app to install and wire in.
PKG=com.immortal.launcher
HOME_ACTIVITY=com.immortal.launcher/.HomeActivity
DREAM_SERVICE=com.immortal.launcher/.PhotoDreamService

# Stock Aloha components — FALLBACKS ONLY. On first provision the script detects
# this device's real stock launcher + screensaver and saves them on the device
# (/sdcard/immortal_restore.env); --restore uses that snapshot so it's correct on
# any Portal model. These values (Portal Go / touchscreen Aloha) are used only if
# no snapshot is found.
STOCK_HOME=com.facebook.alohaapps.launcher/com.facebook.aloha.app.home.touch.HomeActivity
STOCK_DREAM=com.facebook.alohaapps.launcher/com.facebook.aloha.app.home.touch.HomeDreamService
# Portal's dock/idle screensaver default (separate from the active component).
STOCK_DEFAULT_DREAM=com.facebook.alohaapps.superframe/com.facebook.alohaapps.superframe.SuperframeDream

# Meta's required package verifier (the cert allowlist that blocks on-device installs).
VERIFIER_PKG=com.facebook.appverifier

# Which steps to perform.
# SET_LAUNCHER replaces the SYSTEM home with our launcher (reversible via
# --restore). True = full replacement (the goal): our launcher becomes the home.
# Set false if you'd rather it install as a normal app you open from the stock
# home and exit via its "Portal Home" tile.
SET_LAUNCHER=true
SET_SCREENSAVER=true
DISABLE_VERIFIER=true

# Block Meta OS updates so a future OTA can't undo this setup or re-enable the
# verifier. Reversible — restore re-enables them. Portal is discontinued, so this
# also forgoes any (unlikely) future security patches. Set false to keep updates.
DISABLE_OTA=true
OTA_PACKAGES="com.facebook.aloha.alohaotasetup com.facebook.aloha.otaui"

# Runtime permissions to pre-grant (space separated). Immortal needs none at
# runtime (install/delete are install-time perms), so this is empty.
PERMISSIONS=""

# Apps to pre-install during provisioning, via silent `adb install`. This is the
# reliable way to add apps on models whose on-device installer dialog is broken
# (notably the Gen-1 Portal+ on Android 9). It also gives every freshly
# provisioned Portal a few useful apps out of the box.
#   PREINSTALL_FDROID - F-Droid apps as "id" or "id:versionCode". Pin the arm64
#                       versionCode for multi-ABI apps (e.g. VLC), since Portal is arm64.
#   PREINSTALL_APKS   - direct APK URLs (your own apps / specific builds).
# Empty by default — a fresh Portal gets the built-in tiles plus the full App Store
# to install from (and Aurora/Shizuku on Gen-1). Add space-separated F-Droid IDs to
# preinstall some, e.g. "org.videolan.vlc:13070106 io.homeassistant.companion.android.minimal".
# Pin the arm64 versionCode for multi-ABI apps (e.g. VLC), since Portal is arm64.
PREINSTALL_FDROID=""
PREINSTALL_APKS=""

# Relative paths (to this folder).
#   APK_GLOB   - the client APK to install (first match used)
#   ASSET_DIR  - any .jpg here is pushed to the app's files dir; the first is named frame.jpg
APK_GLOB=apks/*.apk
ASSET_DIR=assets

# If no local APK is found in apks/, the provisioner downloads this one. Points
# at the latest signed Immortal release.
RELEASE_APK_URL=https://github.com/starbrightlab/immortal/releases/latest/download/immortal.apk

# Shizuku — lets third-party stores install silently on the Gen-1 Portal+ (Android
# 9), whose stock installer is broken. This is what makes Aurora Store work there:
# Aurora's own Session/Native installers can't get past the broken dialog, but its
# *Shizuku* installer can. With this URL set, provisioning installs Shizuku and
# starts its server automatically on Gen-1 devices (it's skipped on newer Portals,
# which don't need it). Like our own daemon, the server must be restarted after a
# reboot — the kit does that on its next run, or `./provision.sh --shizuku`.
# The user still flips two switches inside Aurora once (Settings -> Installation ->
# Installation method -> Shizuku, then "Allow"); those live in Aurora's private
# settings and can't be pre-set from here.
# Set blank to skip installing Shizuku entirely. Latest: https://github.com/RikkaApps/Shizuku/releases
SHIZUKU_APK_URL="https://github.com/RikkaApps/Shizuku/releases/download/v13.6.0/shizuku-v13.6.0.r1086.2650830c-release.apk"
