# Portal provisioning configuration.
# Edit these to point at your own client app / assets. Both provision.sh and
# provision.ps1 read this file.

# Package + components of the client app to install and wire in.
PKG=com.immortal.launcher
HOME_ACTIVITY=com.immortal.launcher/.HomeActivity
DREAM_SERVICE=com.immortal.launcher/.PhotoDreamService

# Stock Aloha components - FALLBACKS ONLY. On first provision the script detects
# this device's real stock launcher + screensaver and saves them on the device
# (/sdcard/immortal_restore.env); --restore uses that snapshot so it's correct on
# any Portal model. These values (Portal Go / touchscreen Aloha) are used only if
# no snapshot is found.
STOCK_HOME=com.facebook.alohaapps.launcher/com.facebook.aloha.app.home.touch.HomeActivity
STOCK_DREAM=com.facebook.alohaapps.launcher/com.facebook.aloha.app.home.touch.HomeDreamService
# Portal's dock/idle screensaver default (separate from the active component).
STOCK_DEFAULT_DREAM=com.facebook.alohaapps.superframe/com.facebook.alohaapps.superframe.SuperframeDream

# Meta's required package verifier (the cert allowlist that blocks on-device installs).
VERIFIER_PKG=com.facebook.appverifier

# GEN-1 PORTAL+ ONLY. Meta ships a Runtime Resource Overlay (RRO) that re-themes
# framework resources so the stock package-installer dialog renders white-on-white
# (blank confirm screen, invisible "Install" button in the bottom-right corner).
# Disabling the overlay restores normal styling, making the on-device installer
# dialog usable again. Unlike the silent daemon and Shizuku, overlay state is
# persisted by the framework (/data/system/overlays.xml) and SURVIVES A REBOOT, so
# a rebooted Gen-1 with the daemon down still has a working stock installer for
# Aurora/F-Droid/sideloads. Applied immediately via `cmd overlay` (no reboot, so
# it can't kill the daemon). Skipped automatically on newer Portals (API >= 29),
# which have a working dialog and don't ship this overlay. Reversible via restore.
DISABLE_INSTALLER_OVERLAY=true
# Overlay package(s) to disable, space separated. The framework overlay is the one
# that breaks the installer dialog; a companion settings overlay
# (com.facebook.aloha.rro.niu.settings) exists on some builds - only ones actually
# present on the device are touched.
INSTALLER_OVERLAY_PKGS="com.facebook.aloha.rro.niu.android"

# Which steps to perform.
# SET_LAUNCHER replaces the SYSTEM home with our launcher (reversible via
# --restore). True = full replacement (the goal): our launcher becomes the home.
# Set false if you'd rather it install as a normal app you open from the stock
# home and exit via its "Portal Home" tile.
SET_LAUNCHER=true
SET_SCREENSAVER=true
DISABLE_VERIFIER=true
# Meta's camera-based presence detector. The system uses it to decide ambient
# vs sleep at the screen timeout (someone nearby -> photos, empty room -> sleep)
# and Immortal cooperates with it, so it stays ENABLED by default. Set true only
# if you want it off (e.g. no camera use at all); restore re-enables it.
PRESENCE_PKG=com.facebook.alohaservices.presence
DISABLE_PRESENCE=false

# Block Meta OS updates so a future OTA can't undo this setup or re-enable the
# verifier. Reversible - restore re-enables them. Portal is discontinued, so this
# also forgoes any (unlikely) future security patches. Set false to keep updates.
DISABLE_OTA=true
OTA_PACKAGES="com.facebook.aloha.alohaotasetup com.facebook.aloha.otaui"

# Runtime permissions to pre-grant (space separated). Immortal needs none at
# runtime (install/delete are install-time perms), so this is empty.
PERMISSIONS=""

# Apps to pre-install during provisioning, via silent `adb install`. This is the
# reliable way to add apps on models whose on-device installer dialog is broken
# (notably the Gen-1 Portal+ on Android 9). It also gives every freshly
# provisioned Portal a few useful apps out of the box.
#   PREINSTALL_FDROID - F-Droid apps as "id" or "id:versionCode". Pin the arm64
#                       versionCode for multi-ABI apps (e.g. VLC), since Portal is arm64.
#   PREINSTALL_APKS   - direct APK URLs (your own apps / specific builds).
# Empty by default - a fresh Portal gets the built-in tiles plus the full App Store
# to install from (and Aurora/Shizuku on Gen-1). Add space-separated F-Droid IDs to
# preinstall some, e.g. "org.videolan.vlc:13070106 io.homeassistant.companion.android.minimal".
# Pin the arm64 versionCode for multi-ABI apps (e.g. VLC), since Portal is arm64.
PREINSTALL_FDROID=""
PREINSTALL_APKS=""

# ---- WiFi fleet management ---------------------------------------------------
# Enable the in-app Fleet Agent: a foreground service Immortal runs so you can
# manage this Portal over WiFi - deploy/update apps, push config, browse files,
# read logcat - from the portal-explorer "Fleet" view, WITHOUT a USB cable each
# time. Because it's an app service it SURVIVES A REBOOT (unlike adb-over-WiFi on
# these non-root Portals). Provisioning names + enables the agent and records this
# device (name, IP, agent token) to a host-side inventory under fleet/.
#
# We deliberately do NOT switch the Portal into raw adb-over-WiFi during
# provisioning: `adb tcpip` restarts adbd, which would stop Shizuku and the
# silent-install daemon, and it doesn't survive a reboot anyway. The agent covers
# day-to-day management; for an occasional raw adb shell / scrcpy, run
# `./provision.sh --wifi-adb` on demand.
ENABLE_FLEET=true
# Friendly name for THIS device in the fleet dashboard. Blank = prompt when run
# interactively, else fall back to the model. Set per device, e.g.
# FLEET_NAME="Living Room Left".
FLEET_NAME=
FLEET_AGENT_PORT=8723

# Relative paths (to this folder).
#   APK_GLOB   - the client APK to install (first match used)
#   ASSET_DIR  - any .jpg here is pushed to the app's files dir; the first is named frame.jpg
APK_GLOB=apks/*.apk
ASSET_DIR=assets

# If no local APK is found in apks/, the provisioner downloads this one. Points
# at the latest signed Immortal release.
RELEASE_APK_URL=https://github.com/starbrightlab/immortal/releases/latest/download/immortal.apk

# Shizuku - a privileged broker started once over ADB. We install + start it on
# EVERY Portal now: it's broadly useful (Aurora Store's silent installs; the future
# on-device Alexa-restore path that needs the privileged grants) and harmless where
# unused. The Gen-1 Portal+ (Android 9) especially needs it because its stock
# installer dialog is broken - Aurora's Session/Native installers can't get past it,
# but its *Shizuku* installer can. Like our own daemon, the server must be restarted
# after a reboot - the kit does that on its next run, or `./provision.sh --shizuku`.
# For Aurora the user still flips two switches once (Settings -> Installation ->
# Installation method -> Shizuku, then "Allow"); those live in Aurora's private
# settings and can't be pre-set from here.
# Set blank to skip installing Shizuku entirely. Latest: https://github.com/RikkaApps/Shizuku/releases
SHIZUKU_APK_URL="https://github.com/RikkaApps/Shizuku/releases/download/v13.6.0/shizuku-v13.6.0.r1086.2650830c-release.apk"

# ---- Restore the original Amazon Alexa app (the "hey" free tier) -------------
# Optional. Revives the discontinued on-device Alexa client ("falcon") so the
# Portal does hands-free "Hey Alexa" again (text + voice + visual). We never host
# Amazon's binary: the user downloads the PUBLIC stock APK from a firmware dump,
# and we ship only a BINARY DIFF that reconstructs our patched+signed build
# byte-for-byte. Run inline (you're asked y/N during provisioning) or standalone
# with `./provision.sh --alexa`. NEVER uninstalls falcon (that would register a
# new ghost device with Amazon); --restore removes only the wake-word app.
#
# RESTORE_ALEXA: blank = ask when interactive (skip in CI); true/false = force.
RESTORE_ALEXA=
FALCON_PKG=com.amazon.alexa.multimodal.falcon
# PRIMARY source: the patched falcon APK, hosted directly. A single cross-platform download -
# no bspatch (Windows has none), no flaky firmware-dump fetch, no stock+diff checksum drift.
# This is what nearly everyone uses. (If this is ever taken down, blank it and the reconstruct
# fallback below kicks back in.)
FALCON_PATCHED_URL="https://github.com/starbrightlab/hey-dist/releases/download/v0.1.0/falcon.apk"
# FALLBACK only (used when FALCON_PATCHED_URL is blank): reconstruct the same APK from the public
# Portal firmware dump (tadiphone) + our binary diff. Needs bspatch - macOS/Linux only.
FALCON_STOCK_URL="https://dumps.tadiphone.dev/dumps/facebook/aloha/-/raw/aloha_prod-user-9-PKQ1.191202.001-1041481900013050-prod-keys/system/system/app/amazon_alexa/amazon_alexa.apk"
FALCON_STOCK_SHA256=d8f9e0aeec3f1d0a9e132643fc6d4fbbaf4e11e9955dc1bbcd6c1c4e3833e9db
FALCON_BSDIFF_URL="https://github.com/starbrightlab/hey-dist/releases/download/v0.1.0/falcon.bsdiff"
# drop-5 build (5 dee.app-shared <permission> drops) - the A9-validated canonical that the
# hosted falcon.bsdiff actually reconstructs. (drop-7 added EXTENSION/SKILL drops for the A10
# Portal Go's newer dee.app, but A10 isn't supported yet + drop-7 was never re-validated on A9.)
FALCON_RESULT_SHA256=76133f807e492e46aaf58e6ae503e623a93af840eaa3eccfb8630f1ecab3268d
# The "hey" wake-word app (free build).
MILLENNIUM_PKG=com.millennium
MILLENNIUM_APK_URL="https://github.com/starbrightlab/hey-dist/releases/download/v0.1.0/millennium.apk"
# Local-path overrides for testing before the hosted URLs exist (any that are set
# and exist are used instead of downloading):
#   FALCON_PATCHED_LOCAL  pre-built patched+signed falcon APK (skips stock+bspatch)
#   FALCON_STOCK_LOCAL    stock falcon APK (skips the ~120 MB download)
#   FALCON_BSDIFF_LOCAL   our falcon.bsdiff
#   MILLENNIUM_APK_LOCAL  the millennium APK
FALCON_PATCHED_LOCAL=
FALCON_STOCK_LOCAL=
FALCON_BSDIFF_LOCAL=
MILLENNIUM_APK_LOCAL=
# WINDOWS ONLY: macOS/Linux have bspatch; Windows ships none. Point this at a
# bspatch.exe to enable the reconstruct path on Windows, or set FALCON_PATCHED_LOCAL
# instead. Ignored by the bash script (it finds bspatch on PATH). Blank = the
# Windows -Alexa step skips falcon reconstruction with guidance.
BSPATCH_EXE=
